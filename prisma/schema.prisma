generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  COORDINATOR
  TEACHER
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClassroomStatus {
  AVAILABLE
  UNAVAILABLE
  MAINTENANCE
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

model User {
  id             Int                @id @default(autoincrement())
  name           String
  email          String             @unique
  passwordHash   String
  role           UserRole           @default(COORDINATOR)
  active         Boolean            @default(true)
  careerId       Int?
  career         Career?            @relation(fields: [careerId], references: [id])
  requests       ClassroomRequest[] @relation("CreatedRequests")
  reviewed       ClassroomRequest[] @relation("ReviewedRequests")
  assignedGroups AcademicGroup[]
  sessions       Session[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Career {
  id        Int                @id @default(autoincrement())
  name      String
  acronym   String             @unique
  users     User[]
  subjects  Subject[]
  groups    AcademicGroup[]
  requests  ClassroomRequest[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model Subject {
  id            Int                @id @default(autoincrement())
  code          String             @unique
  name          String
  coordination  String             @default("Coordinación")
  semester      Int
  careers       Career[]
  groupSubjects GroupSubject[]
  requests      ClassroomRequest[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model AcademicGroup {
  id            Int            @id @default(autoincrement())
  code          String
  careerId      Int
  career        Career         @relation(fields: [careerId], references: [id])
  semester      Int
  students      Int
  coordinatorId Int
  coordinator   User           @relation(fields: [coordinatorId], references: [id])
  subjects      GroupSubject[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([code, careerId, semester])
}

model GroupSubject {
  id        Int                @id @default(autoincrement())
  groupId   Int
  group     AcademicGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subjectId Int
  subject   Subject            @relation(fields: [subjectId], references: [id])
  requests  ClassroomRequest[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([groupId, subjectId])
}

model SchoolHour {
  id          Int                         @id @default(autoincrement())
  code        String                      @unique
  shift       String
  startTime   String
  endTime     String
  sortOrder   Int
  requests    ClassroomRequest[]
  unavailable ClassroomUnavailableSlot[]
}

model Classroom {
  id          Int                         @id @default(autoincrement())
  number      String
  building    String
  floor       Int                         @default(1)
  capacity    Int
  type        String
  status      ClassroomStatus             @default(AVAILABLE)
  blockReason String?
  requests    ClassroomRequest[]
  unavailable ClassroomUnavailableSlot[]
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt

  @@unique([number, building])
}

model ClassroomUnavailableSlot {
  id           Int        @id @default(autoincrement())
  classroomId  Int
  classroom    Classroom  @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  dayOfWeek    WeekDay
  schoolHourId Int
  schoolHour   SchoolHour @relation(fields: [schoolHourId], references: [id], onDelete: Cascade)
  reason       String     @default("Mantenimiento")
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())

  @@unique([classroomId, dayOfWeek, schoolHourId])
}

model ClassroomRequest {
  id              Int            @id @default(autoincrement())
  coordinatorId   Int
  coordinator     User           @relation("CreatedRequests", fields: [coordinatorId], references: [id])
  careerId        Int
  career          Career         @relation(fields: [careerId], references: [id])
  subjectId       Int
  subject         Subject        @relation(fields: [subjectId], references: [id])
  groupSubjectId  Int?
  groupSubject    GroupSubject?  @relation(fields: [groupSubjectId], references: [id])
  classroomId     Int
  classroom       Classroom      @relation(fields: [classroomId], references: [id])
  semester        Int
  dayOfWeek       WeekDay
  schoolHourId    Int
  schoolHour      SchoolHour     @relation(fields: [schoolHourId], references: [id])
  status          RequestStatus  @default(PENDING)
  rejectionReason String?
  reviewedById    Int?
  reviewedBy      User?          @relation("ReviewedRequests", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  requestedAt     DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}
