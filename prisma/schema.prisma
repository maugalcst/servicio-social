generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  COORDINATOR
  TEACHER
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClassroomStatus {
  AVAILABLE
  UNAVAILABLE
  MAINTENANCE
}

model User {
  id           Int                @id @default(autoincrement())
  name         String
  email        String             @unique
  passwordHash String
  role         UserRole           @default(COORDINATOR)
  active       Boolean            @default(true)
  careerId     Int?
  career       Career?            @relation(fields: [careerId], references: [id])
  requests     ClassroomRequest[] @relation("CreatedRequests")
  reviewed     ClassroomRequest[] @relation("ReviewedRequests")
  sessions     Session[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Career {
  id        Int                @id @default(autoincrement())
  name      String
  acronym   String             @unique
  users     User[]
  subjects  Subject[]
  requests  ClassroomRequest[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model Subject {
  id           Int                @id @default(autoincrement())
  code         String             @unique
  name         String
  coordination String             @default("Coordinación")
  semester     Int
  careers      Career[]
  requests     ClassroomRequest[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model Classroom {
  id        Int                 @id @default(autoincrement())
  number    String
  building  String
  floor     Int                 @default(1)
  capacity  Int
  type      String
  status    ClassroomStatus     @default(AVAILABLE)
  requests  ClassroomRequest[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([number, building])
}

model ClassroomRequest {
  id              Int           @id @default(autoincrement())
  coordinatorId   Int
  coordinator     User          @relation("CreatedRequests", fields: [coordinatorId], references: [id])
  careerId        Int
  career          Career        @relation(fields: [careerId], references: [id])
  subjectId       Int
  subject         Subject       @relation(fields: [subjectId], references: [id])
  classroomId     Int
  classroom       Classroom     @relation(fields: [classroomId], references: [id])
  semester        Int
  status          RequestStatus @default(PENDING)
  rejectionReason String?
  reviewedById    Int?
  reviewedBy      User?         @relation("ReviewedRequests", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  requestedAt     DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}
